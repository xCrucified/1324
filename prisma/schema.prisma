generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  title       String
  price       Float
  description String?  @db.Text
  image       String?
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}